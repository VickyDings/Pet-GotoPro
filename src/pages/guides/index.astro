---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PET_CATEGORIES } from '../../consts.js';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const countByPet = Object.fromEntries(
  PET_CATEGORIES.map((cat) => [
    cat.slug,
    allGuides.filter((g) => g.data.pet === cat.slug).length,
  ])
);

const title = 'Pet Care Guides';
const description =
  'In-depth guides on caring for your pet — from first-week checklists for new puppies to advanced aquarium setup, reptile husbandry, and behavioral training.';
---

<BaseLayout title={title} description={description}>
  <section class="category-hero">
    <div class="container">
      <div class="breadcrumbs">
        <a href="/">Home</a> › <span aria-current="page">Guides</span>
      </div>
      <h1>Pet Care Guides</h1>
      <p class="hero-lede">{description}</p>
    </div>
  </section>

  <section class="container" style="padding: 3rem 1rem 5rem;">
    <div class="category-grid">
      {PET_CATEGORIES.map((cat) => {
        const count = countByPet[cat.slug] || 0;
        return (
          <a href={`/guides/${cat.slug}/`} class="category-card">
            <div class="category-icon" style={`color: ${cat.color};`}>{cat.icon}</div>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
            <div style="font-size: 0.85rem; color: var(--primary); font-weight: 600; margin-top: auto;">
              {count} {count === 1 ? 'guide' : 'guides'} →
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
