---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts.js';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news', ({ data }) => !data.draft);
  return news.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

let author = null;
try {
  author = await getEntry('authors', post.data.author);
} catch (e) {
  // No author file yet
}

const formatDate = (date) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const heroSrc =
  typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src;

const urgencyLabel =
  post.data.urgency === 'breaking' ? 'Breaking News' :
  post.data.urgency === 'alert' ? 'Alert' : 'News';

const urgencyColor =
  post.data.urgency === 'breaking' ? 'var(--error)' :
  post.data.urgency === 'alert' ? 'var(--warning)' : 'var(--primary)';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.data.title,
  description: post.data.description,
  image: new URL(heroSrc, Astro.site).toString(),
  datePublished: post.data.pubDate.toISOString(),
  author: {
    '@type': author ? 'Person' : 'Organization',
    name: author?.data.name || SITE.name,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/pet-gotopro-logo.png', Astro.site).toString(),
    },
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={heroSrc}
  articleType="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <article>
    <div class="container-narrow" style="padding: 2rem 1rem 0;">
      <div class="breadcrumbs">
        <a href="/">Home</a> › <a href="/news/">News</a> › <span aria-current="page">{post.data.title}</span>
      </div>

      <div style={`font-size: 0.85rem; color: ${urgencyColor}; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem;`}>
        {urgencyLabel}
      </div>

      <h1 style="margin-bottom: 1rem;">{post.data.title}</h1>

      <p style="font-family: var(--font-display); font-style: italic; font-size: 1.2rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.5rem;">
        {post.data.description}
      </p>

      <div class="article-meta">
        {author && (
          <span><strong>By:</strong> <a href={`/authors/${author.slug}/`}>{author.data.name}</a></span>
        )}
        <span><strong>Published:</strong> {formatDate(post.data.pubDate)}</span>
      </div>
    </div>

    <div class="container-narrow" style="padding: 1rem;">
      <img
        src={heroSrc}
        alt={post.data.heroImageAlt}
        style="width: 100%; border-radius: var(--radius-lg);"
        loading="eager"
      />
    </div>

    <div class="page-content prose">
      <Content />
    </div>
  </article>
</BaseLayout>
